// Tailscale ACL — source of truth for the tailnet policy.
//
// This file is automatically applied to Tailscale on every push to main via
// .github/workflows/tailscale-acl.yml (using tailscale/gitops-acl-action).
// PRs run a dry-run validation; merged commits apply the policy.
//
// DO NOT edit the policy in the Tailscale admin console — changes there will
// be overwritten on the next push. Edit this file, open a PR, merge.
//
// Tags:
//   tag:k8s-operator  Pi K3s Tailscale operator + operator-managed proxies/exit-nodes.
//   tag:inference     Beelink AI inference appliance (Ollama + LiteLLM).
//
// Grants summary:
//   - Members can reach each other, k8s-operator nodes, the inference box,
//     the internet (exit node), and the three advertised LAN hosts.
//   - K8s operator can reach members (subnet routing).
//   - Tailscale SSH allowed from members to their own devices (autogroup:self).

{
    "tagOwners": {
        // Infrastructure tags are admin-only to own/apply. This is deliberately
        // NARROWER than "any member" for a tailnet that is growing toward
        // family access: a plain member must not be able to self-assign
        // tag:k8s-operator to a device and thereby (via the exitNode
        // autoApprover below) stand up an auto-approved exit node with no admin
        // review. The in-cluster operator is unaffected — it registers its
        // devices through a dedicated OAuth client that carries the tag, not
        // through a member identity, so tag ownership here does not gate it.
        "tag:k8s-operator": ["autogroup:admin"],
        "tag:inference":    ["autogroup:admin"],
    },

    "autoApprovers": {
        "exitNode": ["tag:k8s-operator"],
    },

    "grants": [
        {"src": ["autogroup:member"], "dst": ["autogroup:member"], "ip": ["*"]},
        {"src": ["tag:k8s-operator"], "dst": ["autogroup:member"], "ip": ["*"]},
        {"src": ["autogroup:member"], "dst": ["tag:k8s-operator"], "ip": ["*"]},
        {"src": ["autogroup:member"], "dst": ["tag:inference"],    "ip": ["*"]},
        {
            "src": ["autogroup:member"],
            "dst": ["autogroup:internet"],
            "ip":  ["*"],
        },
        // Scoped to the LAN hosts actually advertised as subnet routes in
        // clusters/pi-k3s/tailscale-config/connector.yaml — NOT the whole /24.
        // Only these three are routable over the tailnet, so this grants
        // exactly what is reachable today and states the real posture instead
        // of a standing /24 allow. NOTE: if you advertise another host in
        // connector.yaml, add its /32 here too, or member traffic to it will
        // be denied even once the route exists.
        {
            "src": ["autogroup:member"],
            "dst": [
                "192.168.1.55/32",  // Pi-hole primary (pi-k3s)
                "192.168.1.56/32",  // Pi-hole secondary (pi5-worker-1)
                "192.168.1.70/32",  // Beelink
            ],
            "ip": ["*"],
        },
    ],

    "ssh": [
        {
            "action": "check",
            "src":    ["autogroup:member"],
            "dst":    ["autogroup:self"],
            "users":  ["autogroup:nonroot", "root"],
        },
    ],
}
