#!/usr/bin/env bash
# oc — launch opencode with a LiteLLM/qwen key pulled from 1Password at startup.
# One biometric prompt, nothing persisted in your shell (the key lives only in
# opencode's process env, then exec's away).
#
# General-purpose: use it in any project, not just this repo. It depends on the
# local stack (1Password CLI + opencode + a reachable LiteLLM endpoint), so it's
# documented and bootstrapped from here — see scripts/README.md.
#
#   oc                 # interactive TUI (no timeout)
#   oc run "do thing"  # headless one-shot — guarded by a watchdog timeout
#
# Per-machine / per-project override the vault path:
#   OC_KEY_REF="op://work-vault/opencode/key" oc
# Headless watchdog (seconds); a stalled `oc run` is killed instead of hanging:
#   OC_RUN_TIMEOUT=900 oc run "big task"     # default 600s
set -euo pipefail

OC_RUN_TIMEOUT="${OC_RUN_TIMEOUT:-600}"

# Key source, in order: the local macOS Keychain copy (a device->tool cred — no biometric,
# so the agent loop never gets locked out), then 1Password (the canonical copy, for first
# run / re-bootstrap). Re-seed the Keychain any time with:
#   security add-generic-password -U -s opencode-qwen -a oc -T /usr/bin/security \
#     -w "$(op read 'op://pi-cluster/opencode-coder/password')"
KEY="$(security find-generic-password -s opencode-qwen -w 2>/dev/null || true)"
if [ -z "$KEY" ]; then
  KEY_REF="${OC_KEY_REF:-op://pi-cluster/opencode-coder/password}"
  KEY="$(op read "$KEY_REF" 2>/dev/null || true)"
fi
if [ -z "$KEY" ]; then
  echo "oc: no qwen key found — not in the Keychain (service 'opencode-qwen') nor 1Password." >&2
  echo "    Seed the Keychain (see the comment above), or unlock 1Password." >&2
  exit 1
fi
export OPENCODE_QWEN_KEY="$KEY"

# Homelab MCP key (the `ops` diagnostician agent — .opencode/agents/ops.md).
# Keychain hit is free on any launch; only `oc ops` REQUIRES the key and falls back
# to 1Password (Touch ID) — plain coding sessions never prompt for it. Optional seed:
#   security add-generic-password -U -s mcp-homelab -a oc -T /usr/bin/security \
#     -w "$(op read 'op://pi-cluster/mcp-homelab/api-key')"
MCP_KEY="$(security find-generic-password -s mcp-homelab -w 2>/dev/null || true)"
if [ "${1:-}" = "ops" ]; then
  shift
  if [ -z "$MCP_KEY" ]; then
    MCP_KEY="$(op read "${OC_MCP_KEY_REF:-op://pi-cluster/mcp-homelab/api-key}" 2>/dev/null || true)"
  fi
  if [ -z "$MCP_KEY" ]; then
    echo "oc ops: no mcp-homelab key — not in the Keychain (service 'mcp-homelab') nor 1Password." >&2
    exit 1
  fi
  export MCP_HOMELAB_KEY="$MCP_KEY"
  exec opencode --agent ops "$@"
fi
if [ -n "$MCP_KEY" ]; then export MCP_HOMELAB_KEY="$MCP_KEY"; fi

# Interactive TUI (no `run` subcommand) → hand off directly, no timeout.
if [ "${1:-}" != "run" ]; then
  exec opencode "$@"
fi

# Headless `run` → prepend the navigation codesheet (repo map + the sheet the
# repo's shape calls for) to the prompt. Measured on 783 trials: 20-56% less
# context at equal-or-better accuracy, ~free after first use via prefix cache
# (docs/research/codemap-serena-token-efficiency.md). OC_SHEET=off disables;
# OC_SHEET_GEN overrides the generator path. Silently skipped when no
# generator is reachable, so `oc run` keeps working on any machine.
if [ "${OC_SHEET:-on}" = "on" ]; then
  # Target repo = --dir's value if present, else cwd.
  sheet_dir="$PWD"
  _prev=""
  for _a in "$@"; do
    [ "$_prev" = "--dir" ] && sheet_dir="$_a"
    _prev="$_a"
  done
  SHEET_GEN="${OC_SHEET_GEN:-}"
  if [ -z "$SHEET_GEN" ] && [ -f "$sheet_dir/scripts/gen-codesheet.mjs" ]; then
    SHEET_GEN="$sheet_dir/scripts/gen-codesheet.mjs"
  fi
  # Canonical checkout: $HOME/dev on the laptop; the harness containers clone
  # at the literal laptop path (that's what makes memory-dir slugs match).
  for _cand in "$HOME/dev/pi-cluster" "/Users/mtgibbs/dev/pi-cluster"; do
    if [ -z "$SHEET_GEN" ] && [ -f "$_cand/scripts/gen-codesheet.mjs" ]; then
      SHEET_GEN="$_cand/scripts/gen-codesheet.mjs"
    fi
  done
  if [ -n "$SHEET_GEN" ] && command -v node >/dev/null 2>&1; then
    sheet="$(node "$SHEET_GEN" "$sheet_dir" 2>/dev/null || true)"
    if [ -n "$sheet" ]; then
      # Prepend to the FIRST message word (args after `run` that aren't flags
      # or a value of a value-taking flag) — the sheet must precede the
      # question, matching the measured prompt shape.
      args=("$@"); _prev=""; injected=0
      for i in "${!args[@]}"; do
        if [ "$i" = 0 ]; then continue; fi             # the `run` word itself
        case "$_prev" in --dir|--agent|--model|-m|--session|-s) _prev="${args[$i]}"; continue;; esac
        _prev="${args[$i]}"
        case "${args[$i]}" in -*) continue;; esac
        args[$i]="${sheet}

${args[$i]}"
        injected=1
        break
      done
      if [ "$injected" = 1 ]; then set -- "${args[@]}"; fi
    fi
  fi
fi

# Guard with a watchdog so a stalled stream can't hang for hours
# (a local agentic session stalled for 2h once with no timeout — never again).
opencode "$@" &
oc_pid=$!
(
  sleep "$OC_RUN_TIMEOUT"
  if kill -0 "$oc_pid" 2>/dev/null; then
    echo "oc: 'run' exceeded ${OC_RUN_TIMEOUT}s — killing (likely a stalled session)." >&2
    kill "$oc_pid" 2>/dev/null
    sleep 3
    kill -9 "$oc_pid" 2>/dev/null
  fi
) &
watchdog_pid=$!

set +e
wait "$oc_pid"; rc=$?
set -e
kill "$watchdog_pid" 2>/dev/null || true
exit "$rc"
