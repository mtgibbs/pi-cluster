#!/usr/bin/env bash
# agent-bus-bootstrap — one-time account + room bootstrap for the homelab Matrix bus.
#
# Turns a freshly-deployed (Phase 0) Synapse into a usable bus: registers the agent
# users, logs each in for a long-lived token, creates the #agents/#tasks rooms, joins
# everyone, and stores every credential in 1Password (the canonical store `scripts/agent-bus`
# reads from). Implements the "Bootstrap runbook" in docs/agent-bus.md as code.
#
# WHERE THIS RUNS: your laptop (or any host with cluster + 1Password access). NOT inside a
# harness container — registration needs `kubectl exec` into the Synapse pod (the shared
# secret lives only in-pod, never leaves the cluster) and token storage needs `op`. The
# harness containers have neither by design.
#
# WHAT THIS IS FOR NOW: the bus is already bootstrapped (2026-07-17). Reach for this to
# rebuild from scratch, or to ADD AN AGENT — put the new identity in USERS below and re-run;
# everyone who already exists is left alone. It is not a pending step.
#
# IDEMPOTENT, INCLUDING THE TOKENS. Existing users keep their 1Password password AND their
# existing access token: if the stored token still passes /account/whoami, it is reused, not
# reissued. That distinction is the whole safety property. A fresh /login does NOT invalidate
# the old token — it mints a SECOND one — so blindly re-logging in would overwrite 1Password
# with a token that the containers, whose env was populated at deploy time, know nothing
# about. The bus would keep working right up until something re-read 1Password, and then
# quietly not. Use --rotate when you actually want new tokens.
#
# Deps: kubectl (context → the pi-k3s cluster), op (1Password CLI, signed in), curl, jq.
#
#   ./scripts/agent-bus-bootstrap                 # converge (safe on a live bus)
#   ./scripts/agent-bus-bootstrap --verify        # just re-check tokens + rooms, mutate nothing
#   ./scripts/agent-bus-bootstrap --rotate        # force new tokens for everyone (see above)
set -euo pipefail

# --- config (matches clusters/pi-k3s/matrix/*) ------------------------------------------
NS="matrix"
DEPLOY="deploy/synapse"
SECRETS_IN_POD="/synapse/secrets/homeserver-secrets.yaml"
HS="https://matrix.lab.mtgibbs.dev"          # homeserver base URL (public ingress)
DOMAIN="matrix.lab.mtgibbs.dev"              # server_name → user/room suffix
VAULT="pi-cluster"
CS="$HS/_matrix/client/v3"

# user  admin?   (one Matrix identity per agent + the human admin; see docs/agent-bus.md)
USERS=(
  "matt:admin"
  "laptop-claude:user"
  "harness-claude:user"
  "harness-claude-2:user"
  "qwen:user"
  "codex:user"
  # Not an executor -- the pulse dashboard's collector, which only ever READS the bus
  # (/sync long-poll) to animate who-talked-to-whom. Same one-identity-per-role rule as
  # the agents: it gets its own, so a message from an agent is never confusable with the
  # observer watching them.
  "pulse:user"
)
ROOMS=("agents" "tasks")

VERIFY_ONLY=0; ROTATE=0
case "${1:-}" in
  --verify) VERIFY_ONLY=1 ;;
  --rotate) ROTATE=1 ;;
  "") ;;
  *) printf 'usage: %s [--verify|--rotate]\n' "$0" >&2; exit 2 ;;
esac

# --- helpers ----------------------------------------------------------------------------
# All logging goes to stderr so functions can "return" a value on stdout via $(...)
# without the log lines being captured into it.
say()  { printf '\033[1;36m==>\033[0m %s\n' "$*" >&2; }
ok()   { printf '  \033[32m✓\033[0m %s\n' "$*" >&2; }
warn() { printf '  \033[33m!\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[31magent-bus-bootstrap: %s\033[0m\n' "$*" >&2; exit 1; }
uid_of() { printf '@%s:%s' "$1" "$DOMAIN"; }
op_item() { printf 'agent-bus-%s' "$1"; }

for b in kubectl op curl jq openssl; do command -v "$b" >/dev/null || die "missing dependency: $b"; done

# Parallel indexed arrays, NOT `declare -A`. macOS ships bash 3.2, which has no associative
# arrays — `declare -A` is a hard syntax error there ("invalid option"), and the laptop is
# exactly where this script's header says to run it. The original main path died on that
# line every time; --verify appeared to work only because it exits before reaching it.
# Indexed arrays and ${!arr[@]} are fine in 3.2, so this stays portable without a bash5 dep.
TOK_NAMES=(); TOK_VALS=()
tok_set() { TOK_NAMES[${#TOK_NAMES[@]}]="$1"; TOK_VALS[${#TOK_VALS[@]}]="$2"; }
tok_get() {
  local i
  for i in $(seq 0 $(( ${#TOK_NAMES[@]} - 1 )) ); do
    [ "${TOK_NAMES[$i]}" = "$1" ] && { printf '%s' "${TOK_VALS[$i]}"; return 0; }
  done
  return 1
}

ROOM_NAMES=(); ROOM_VALS=()
room_set() { ROOM_NAMES[${#ROOM_NAMES[@]}]="$1"; ROOM_VALS[${#ROOM_VALS[@]}]="$2"; }
room_get() {
  local i
  for i in $(seq 0 $(( ${#ROOM_NAMES[@]} - 1 )) ); do
    [ "${ROOM_NAMES[$i]}" = "$1" ] && { printf '%s' "${ROOM_VALS[$i]}"; return 0; }
  done
  return 1
}

preflight() {
  say "Preflight"
  kubectl -n "$NS" get "$DEPLOY" >/dev/null 2>&1 || die "can't see $DEPLOY in ns/$NS — is your kubectl context the pi-k3s cluster?"
  kubectl -n "$NS" rollout status "$DEPLOY" --timeout=30s >/dev/null 2>&1 || die "synapse not ready — check: kubectl -n $NS get pods"
  # Probe op with the operation this script actually uses, and only warn.
  #
  # `op whoami` and `op vault get` both need an account-level session. The laptop this runs
  # on does not have one — its op resolves secret references through the desktop app, where
  # `op read` succeeds while BOTH of those fail. Gating on them refuses to run on a working
  # setup: verified 2026-07-21, whoami and vault-get failing while `op read` returned the
  # token fine. Reading matt's token proves the path end to end; falling back to vault-get
  # covers a genuine first bootstrap, where that item does not exist yet.
  #
  # A failed probe is a warning, not a stop: every read below dies loudly and actionably on
  # its own, and refusing to start on a false negative is the worse failure.
  if ! op read "op://$VAULT/$(op_item matt)/token" >/dev/null 2>&1 \
     && ! op vault get "$VAULT" >/dev/null 2>&1; then
    warn "1Password did not answer a test read — continuing; if it's locked, the first read below will say so"
  fi
  local v; v="$(curl -fsS -m 10 "$HS/_matrix/client/versions" | jq -r '.versions[-1]' 2>/dev/null || true)"
  [ -n "$v" ] || die "homeserver $HS/_matrix/client/versions did not answer"
  ok "synapse ready in ns/$NS; op signed in; homeserver speaks client API ($v)"
}

# mint a password: hex only (no shell/JSON quoting hazards through kubectl exec + curl;
# no pipe → no pipefail/SIGPIPE hazard). 48 hex chars ≈ 192 bits.
mint_pw() { openssl rand -hex 24; }

# password source of truth = 1Password. Reuse if the item exists, else mint fresh.
get_or_mint_pw() {
  local name="$1" item; item="$(op_item "$name")"
  if op item get "$item" --vault "$VAULT" >/dev/null 2>&1; then
    op read "op://$VAULT/$item/password" 2>/dev/null || mint_pw
  else
    mint_pw
  fi
}

# register a user via the in-pod shared secret (idempotent: "already taken" is fine)
register_user() {
  local name="$1" admin="$2" pw="$3" flag="--no-admin"
  [ "$admin" = "admin" ] && flag="--admin"
  local out rc=0
  out="$(kubectl -n "$NS" exec -i "$DEPLOY" -- \
        register_new_matrix_user -c "$SECRETS_IN_POD" -u "$name" -p "$pw" "$flag" \
        http://localhost:8008 2>&1)" || rc=$?
  if [ "$rc" = 0 ]; then ok "registered $(uid_of "$name") ($flag)"; return 0; fi
  case "$out" in
    *already*taken*|*M_USER_IN_USE*) ok "$(uid_of "$name") already registered (reusing)"; return 0;;
    *) warn "register $(uid_of "$name") failed: $out"; return 1;;
  esac
}

# A stored token that still authenticates IS the right token — hand it back and skip the
# login entirely. This is what makes the script safe to run against a live bus: see the
# header for why re-issuing would silently desync the harness containers.
existing_token() {
  local name="$1" tok me
  tok="$(op read "op://$VAULT/$(op_item "$name")/token" 2>/dev/null)" || return 1
  [ -n "$tok" ] || return 1
  me="$(curl -fsS -m 10 -H "Authorization: Bearer $tok" "$CS/account/whoami" 2>/dev/null \
        | jq -r '.user_id // empty')" || return 1
  [ "$me" = "$(uid_of "$name")" ] || return 1
  printf '%s' "$tok"
}

# password-login → long-lived access token (m.login.password by user localpart)
login_token() {
  local name="$1" pw="$2" body resp tok
  body="$(jq -nc --arg u "$name" --arg p "$pw" \
    '{type:"m.login.password",identifier:{type:"m.id.user",user:$u},password:$p,initial_device_display_name:"agent-bus"}')"
  resp="$(curl -fsS -X POST -H 'Content-Type: application/json' -d "$body" "$CS/login")" || return 1
  tok="$(printf '%s' "$resp" | jq -r '.access_token // empty')"
  [ -n "$tok" ] || return 1
  printf '%s' "$tok"
}

# store username/password/token/homeserver in 1Password (create or edit — never duplicate)
store_creds() {
  local name="$1" pw="$2" tok="$3" item; item="$(op_item "$name")"
  if op item get "$item" --vault "$VAULT" >/dev/null 2>&1; then
    op item edit "$item" --vault "$VAULT" \
      "username[text]=$(uid_of "$name")" "password[password]=$pw" \
      "token[password]=$tok" "homeserver[text]=$HS" >/dev/null
  else
    op item create --category login --title "$item" --vault "$VAULT" \
      "username[text]=$(uid_of "$name")" "password[password]=$pw" \
      "token[password]=$tok" "homeserver[text]=$HS" >/dev/null
  fi
  ok "1Password: $item (token refreshed)"
}

# who is already in the room — fetched ONCE per room so the converged case costs one
# request instead of two per agent. That isn't just tidiness: Synapse rate-limits, and
# blindly re-inviting everyone on every run earns a 429 that lands on whichever agent is
# unlucky. Seen for real 2026-07-22 adding @pulse — the storm from five redundant invites
# got it throttled out of #tasks, so it joined one room and silently missed the other.
room_members() {
  curl -fsS -m 15 -H "Authorization: Bearer $MATT_TOKEN" \
    "$CS/rooms/$(jq -rn --arg s "$1" '$s|@uri')/joined_members" 2>/dev/null \
    | jq -r '.joined // {} | keys[]' 2>/dev/null || true
}

# resolve an existing room alias → room_id, or empty if it doesn't exist yet
resolve_room() {
  local alias_enc; alias_enc="$(jq -rn --arg s "#$1:$DOMAIN" '$s|@uri')"
  curl -fsS -H "Authorization: Bearer $MATT_TOKEN" "$CS/directory/room/$alias_enc" 2>/dev/null \
    | jq -r '.room_id // empty' 2>/dev/null || true
}

# create #room (private_chat, NO encryption) inviting every agent; reuse if it exists
create_room() {
  local room="$1" rid invites body
  rid="$(resolve_room "$room")"
  if [ -n "$rid" ]; then ok "#$room exists ($rid)"; printf '%s' "$rid"; return; fi
  invites="$(printf '%s\n' "${USERS[@]}" | while IFS=: read -r n _; do [ "$n" = matt ] || uid_of "$n"; done | jq -R . | jq -sc .)"
  body="$(jq -nc --arg n "$room" --arg a "$room" --argjson inv "$invites" \
    '{preset:"private_chat",name:$n,room_alias_name:$a,visibility:"private",invite:$inv}')"
  rid="$(curl -fsS -X POST -H "Authorization: Bearer $MATT_TOKEN" -H 'Content-Type: application/json' \
        -d "$body" "$CS/createRoom" | jq -r '.room_id')"
  [ -n "$rid" ] && [ "$rid" != null ] || die "createRoom #$room failed"
  ok "created #$room ($rid)"
  printf '%s' "$rid"
}

# Invite an agent to an EXISTING room, as matt. Only createRoom carries an invite list, so
# an agent added to USERS after the rooms exist is never invited by that path — and these
# rooms are preset:private_chat, where an uninvited join is refused. Hit for real adding
# @codex on 2026-07-21. Already-in-room is the expected no-op here, not an error.
invite_room() {
  local room_id="$1" name="$2" out
  # NOTE: no -f. Matrix answers an already-a-member invite with 403 + a JSON body naming the
  # reason, and curl's -f throws the body away — leaving only "error: 403" to pattern-match,
  # which turns the single most common case into unreadable noise on every run.
  out="$(curl -sS -X POST -H "Authorization: Bearer $MATT_TOKEN" -H 'Content-Type: application/json' \
        -d "$(jq -nc --arg u "$(uid_of "$name")" '{user_id:$u}')" \
        "$CS/rooms/$(jq -rn --arg s "$room_id" '$s|@uri')/invite" 2>&1)"
  case "$out" in
    *already*in*the*room*|*already*joined*) return 0;;  # expected no-op, stay quiet
    *errcode*) warn "invite $name: $(printf '%s' "$out" | jq -r '.error // .' 2>/dev/null)";;
  esac
  return 0
}

# each invited agent joins the room with its own token (already-joined tolerated)
join_room() {
  local room_id="$1" name="$2" tok="$3" out rc=0
  out="$(curl -fsS -X POST -H "Authorization: Bearer $tok" -H 'Content-Type: application/json' \
        -d '{}' "$CS/join/$(jq -rn --arg s "$room_id" '$s|@uri')" 2>&1)" || rc=$?
  if [ "$rc" = 0 ]; then ok "$(uid_of "$name") joined"; return; fi
  # M_FORBIDDEN is deliberately NOT treated as success. On a private_chat room it means
  # "not invited" at least as often as it means "already here", and swallowing it turns a
  # genuinely-not-in-the-room agent into a green line.
  case "$out" in
    *already*in*room*) ok "$(uid_of "$name") already in room";;
    *) warn "join failed for $name: $out";;
  esac
}

# --- verify (read-only) -----------------------------------------------------------------
do_verify() {
  say "Verify — tokens + room membership"
  local name tok me
  for entry in "${USERS[@]}"; do
    name="${entry%%:*}"
    tok="$(op read "op://$VAULT/$(op_item "$name")/token" 2>/dev/null || true)"
    [ -n "$tok" ] || { warn "$name: no token in 1Password"; continue; }
    me="$(curl -fsS -H "Authorization: Bearer $tok" "$CS/account/whoami" | jq -r '.user_id // empty')"
    [ "$me" = "$(uid_of "$name")" ] && ok "$name → $me (token valid)" || warn "$name: token invalid or mismatched ($me)"
  done
  say "Rooms"
  MATT_TOKEN="$(op read "op://$VAULT/$(op_item matt)/token")"
  for room in "${ROOMS[@]}"; do
    local rid; rid="$(resolve_room "$room")"
    [ -n "$rid" ] && ok "#$room → $rid" || warn "#$room not found"
  done
}

# --- main -------------------------------------------------------------------------------
preflight
if [ "$VERIFY_ONLY" = 1 ]; then do_verify; exit 0; fi

say "Users — register, login, store"
for entry in "${USERS[@]}"; do
  name="${entry%%:*}"; admin="${entry##*:}"

  # Working token already on file → reuse it and touch nothing. This is the branch that
  # makes a re-run against the live bus a no-op instead of a silent credential rotation.
  if [ "$ROTATE" = 0 ] && tok="$(existing_token "$name")"; then
    ok "$(uid_of "$name") token still valid (reused, NOT reissued)"
    tok_set "$name" "$tok"
    continue
  fi

  pw="$(get_or_mint_pw "$name")"
  register_user "$name" "$admin" "$pw"
  tok="$(login_token "$name" "$pw")" || die "login failed for $name (if the user pre-existed with a different password, delete op item $(op_item "$name") and re-run)"
  store_creds "$name" "$pw" "$tok"
  tok_set "$name" "$tok"
done

[ "$ROTATE" = 1 ] && warn "--rotate: every token was reissued. Anything holding an old one (harness container env — see beelink-ansible 50-ai-stack.yml) must be redeployed."

MATT_TOKEN="$(tok_get matt)"
say "Rooms — create #agents/#tasks, invite + join everyone"
for room in "${ROOMS[@]}"; do
  rid="$(create_room "$room")"
  room_set "$room" "$rid"
  members="$(room_members "$rid")"
  for entry in "${USERS[@]}"; do
    name="${entry%%:*}"; [ "$name" = matt ] && continue
    if printf '%s\n' "$members" | grep -qxF "$(uid_of "$name")"; then
      ok "$(uid_of "$name") already in #$room"
      continue
    fi
    invite_room "$rid" "$name"
    join_room "$rid" "$name" "$(tok_get "$name")"
  done
done

say "1Password — store room ids (agent-bus-rooms)"
if op item get "agent-bus-rooms" --vault "$VAULT" >/dev/null 2>&1; then
  op item edit "agent-bus-rooms" --vault "$VAULT" \
    "agents[text]=$(room_get agents)" "tasks[text]=$(room_get tasks)" "domain[text]=$DOMAIN" >/dev/null
else
  op item create --category login --title "agent-bus-rooms" --vault "$VAULT" \
    "agents[text]=$(room_get agents)" "tasks[text]=$(room_get tasks)" "domain[text]=$DOMAIN" >/dev/null
fi
ok "agent-bus-rooms saved"

do_verify

cat <<EOF

==> Bus converged
If you just ADDED an agent, it has an identity but nothing to speak with yet — the token
has to reach wherever that agent runs. Both of these are already wired for the four
harness containers (beelink-ansible 50-ai-stack.yml); a NEW one needs the same treatment:
  • Harness containers: MATRIX_TOKEN + AGENT_BUS_IDENTITY per container, plus jq in the
    image. Config-from-outside — this script cannot do it, and the container has no op.
    Redeploy the ai-stack after adding the extra-var.
  • Laptop convenience: seed Keychain so scripts/agent-bus needs no op prompt, e.g.
      security add-generic-password -U -s agent-bus-laptop-claude -a agent-bus -T /usr/bin/security \\
        -w "\$(op read 'op://$VAULT/agent-bus-laptop-claude/token')"
  • Smoke test:  AGENT_BUS_IDENTITY=laptop-claude scripts/agent-bus post agents "bus online"
                 AGENT_BUS_IDENTITY=matt          scripts/agent-bus read agents
EOF
