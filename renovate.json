{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "America/Chicago",
  "dependencyDashboard": true,
  "automerge": false,
  "kubernetes": {
    "managerFilePatterns": ["/clusters/pi-k3s/.+\\.ya?ml$/"]
  },
  "flux": {
    "managerFilePatterns": ["/clusters/pi-k3s/.+\\.ya?ml$/"]
  },
  "ignorePaths": [
    "clusters/pi-k3s/flux-system/gotk-components.yaml",
    "clusters/pi-k3s/mtgibbs-site/**",
    "clusters/pi-k3s/mcp-homelab/**",
    "clusters/pi-k3s/local-llm-mcp/**",
    "clusters/pi-k3s/kiwix-mcp/**",
    "clusters/pi-k3s/private-exit-node/**"
  ],
  "packageRules": [
    {
      "description": "Servarr stack moves as ONE bundle - minor+major together, reviewed as a unit (like a coordinated framework bump)",
      "groupName": "servarr stack",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "linuxserver/sonarr",
        "linuxserver/radarr",
        "linuxserver/lidarr",
        "linuxserver/prowlarr",
        "linuxserver/bazarr"
      ],
      "separateMajorMinor": false,
      "separateMinorPatch": false
    },
    {
      "description": "Pi-hole uses CalVer YYYY.MM.patch",
      "matchPackageNames": ["pihole/pihole"],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d{2})\\.(?<patch>\\d+)$"
    },
    {
      "description": "cloudflared uses CalVer YYYY.M.patch",
      "matchPackageNames": ["cloudflare/cloudflared"],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "description": "vector ships X.Y.Z-alpine variant tags",
      "matchPackageNames": ["timberio/vector"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-alpine$"
    },
    {
      "description": "Rolling LinuxServer builds (no real versions) - bump these by hand, not Renovate",
      "matchPackageNames": ["lscr.io/linuxserver/lazylibrarian", "linuxserver/readarr"],
      "enabled": false
    }
  ]
}
