    {
      "id": "A1C0FE21-2B7E-49C4-9A0E-1D2F3B4C5D6E",
      "name": "Ensure Board Acks",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        220,
        0
      ],
      "alwaysOutputData": true,
      "parameters": {
        "operation": "executeQuery",
        "query": "CREATE TABLE IF NOT EXISTS board_acks (item_id BIGINT NOT NULL, person TEXT NOT NULL CHECK (person IN ('julia','matt','ronin','rory')), seen_at TIMESTAMPTZ NOT NULL DEFAULT now(), PRIMARY KEY (item_id, person));",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "5bzmWi2TWDCyypLQ",
          "name": "intake-db"
        }
      }
    },
    {
      "id": "BE35730D-91D6-4305-9D3F-45C1C747A50E",
      "name": "Get Feed",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        460,
        0
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT i.id, i.received_at, i.type, i.title, i.due_at, i.student, i.action_required, i.amount, i.teacher, i.course, i.source_hint, i.confidence, i.source_channel, i.source_subject, i.source_from, COALESCE(a.acks, '[]'::json) AS acks FROM intake_items i LEFT JOIN (SELECT item_id, json_agg(person ORDER BY person) AS acks FROM board_acks GROUP BY item_id) a ON a.item_id = i.id ORDER BY (i.due_at IS NULL), i.due_at LIMIT 500;",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "5bzmWi2TWDCyypLQ",
          "name": "intake-db"
        }
      }
    },
    {
      "id": "D1A5121E-A905-4E19-B16F-BA38669844A6",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        700,
        0
      ],
      "parameters": {
        "respondWith": "allIncomingItems",
        "options": {
          "responseHeaders": {
            "entries": [
              {
                "name": "Access-Control-Allow-Origin",
                "value": "*"
              }
            ]
          }
        }
      }
    }
