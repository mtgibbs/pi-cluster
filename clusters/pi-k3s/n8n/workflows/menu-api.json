      "parameters": {
        "operation": "executeQuery",
        "query": "CREATE TABLE IF NOT EXISTS board_menu (id BIGSERIAL PRIMARY KEY, meal TEXT NOT NULL, recipe_url TEXT, eaten BOOLEAN NOT NULL DEFAULT false, position INT, created_at TIMESTAMPTZ NOT NULL DEFAULT now());",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "5bzmWi2TWDCyypLQ",
          "name": "intake-db"
        }
      }
    },
    {
      "id": "40D4E5F6-A7B8-492A-9B31-4D5E6F708193",
      "name": "Route Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        440,
        0
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "typeValidation": "strict" },
                "conditions": [
                  { "leftValue": "={{ $('Menu Webhook').first().json.body.action }}", "rightValue": "list", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "typeValidation": "strict" },
                "conditions": [
                  { "leftValue": "={{ $('Menu Webhook').first().json.body.action }}", "rightValue": "add", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "typeValidation": "strict" },
                "conditions": [
                  { "leftValue": "={{ $('Menu Webhook').first().json.body.action }}", "rightValue": "edit", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "typeValidation": "strict" },
                "conditions": [
                  { "leftValue": "={{ $('Menu Webhook').first().json.body.action }}", "rightValue": "toggle", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "typeValidation": "strict" },
                "conditions": [
                  { "leftValue": "={{ $('Menu Webhook').first().json.body.action }}", "rightValue": "delete", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              }
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "50E5F6A7-B8C9-4A3B-9C41-5E6F70819204",
      "name": "List Menu",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        680,
        -240
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, meal, recipe_url, eaten, position, created_at FROM board_menu ORDER BY COALESCE(position, 0), created_at, id;",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "5bzmWi2TWDCyypLQ",
          "name": "intake-db"
        }
