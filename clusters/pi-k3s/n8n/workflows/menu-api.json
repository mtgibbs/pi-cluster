    },
    {
      "id": "60F6A7B8-C9DA-4B4C-9D51-6F7081920315",
      "name": "Add Meal",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        680,
        -120
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO board_menu (meal, recipe_url) VALUES ($1::text, NULLIF($2::text, '')) RETURNING id, meal, recipe_url, eaten, position, created_at;",
        "options": {
          "queryReplacement": "={{ $('Menu Webhook').first().json.body.meal }},={{ $('Menu Webhook').first().json.body.recipe_url || '' }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "5bzmWi2TWDCyypLQ",
          "name": "intake-db"
        }
      }
    },
    {
      "id": "70A7B8C9-DAEB-4C5D-9E61-708192031426",
      "name": "Edit Meal",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        680,
        0
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE board_menu SET meal = COALESCE(NULLIF($2::text, ''), meal), recipe_url = NULLIF($3::text, '') WHERE id = $1::bigint RETURNING id, meal, recipe_url, eaten, position, created_at;",
        "options": {
          "queryReplacement": "={{ $('Menu Webhook').first().json.body.id }},={{ $('Menu Webhook').first().json.body.meal || '' }},={{ $('Menu Webhook').first().json.body.recipe_url || '' }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "5bzmWi2TWDCyypLQ",
          "name": "intake-db"
        }
      }
    },
    {
      "id": "80B8C9DA-EBFC-4D6E-9F71-819203142537",
      "name": "Toggle Eaten",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        680,
        120
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE board_menu SET eaten = NOT eaten WHERE id = $1::bigint RETURNING id, meal, recipe_url, eaten, position, created_at;",
        "options": {
          "queryReplacement": "={{ $('Menu Webhook').first().json.body.id }}"
        }
      },
      "credentials": {
        "postgres": {
